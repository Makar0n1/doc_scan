{
  "name": "avto-komissiya",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Браузерная утилита для автосалона: фото документов → распознавание ИИ → договор комиссии .docx",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "docx-preview": "^0.3.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "multer": "^2.0.1",
    "sharp": "^0.33.5",
    "pizzip": "^3.1.7",
    "docxtemplater": "^3.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "vite": "^5.4.11",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3"
  }
}
