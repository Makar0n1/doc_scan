# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Модель распознавания (необязательно). По умолчанию qwen/qwen3.5-397b-a17b.
# Альтернативы:
#   google/gemini-3-pro-preview     — лучший OCR/рукопись/кириллица (дороже)
#   google/gemini-3-flash-preview   — дешевле, хороший баланс
#   anthropic/claude-sonnet-4.6     — строже всех следует правилам «не выдумывай»
OPENROUTER_MODEL=qwen/qwen3.5-397b-a17b

# Доступ по паролю. Если не задать — вход отключён (открытый доступ).
#   AUTH_PASSWORD  — один общий пароль
#   AUTH_PASSWORDS — несколько паролей через запятую (напр. для тебя и клиента)
#   AUTH_SECRET    — секрет для подписи сессии (любая длинная случайная строка);
#                    если не задан — выводится из пароля. Сессия живёт 90 дней.
AUTH_PASSWORD=измените-меня
AUTH_SECRET=

# Порт бэкенда (по умолчанию 3000). В dev Vite проксирует /api на этот порт.
PORT=3000
